---
const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.condocombat.com';

const navLinks = [
  { label: 'Início', href: '#hero' },
  { label: 'Recursos', href: '#recursos' },
  { label: 'Diferenciais', href: '#diferenciais' },
  { label: 'Contato', href: '#contato' },
]
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/80 backdrop-blur">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Navegação principal">
    <a href="/" class="flex items-center gap-2 text-xl font-bold text-rose-600">
      <span aria-hidden="true">🏢</span>
      <span>CondoCombat</span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-slate-600 transition-colors hover:text-rose-600"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href={appUrl}
      class="hidden rounded-lg bg-rose-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-rose-700 md:inline-block"
    >
      Acessar Plataforma
    </a>

    <details class="group md:hidden">
      <summary class="flex cursor-pointer list-none items-center gap-2 text-slate-600">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path class="group-open:hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path class="hidden group-open:block" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
        <span class="sr-only">Abrir menu</span>
      </summary>
      <div class="absolute left-0 right-0 top-full border-b border-slate-200 bg-white px-4 pb-6 pt-4 shadow-lg">
        <ul class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="block rounded-lg px-4 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-rose-600"
              >
                {link.label}
              </a>
            </li>
          ))}
          <li class="pt-2">
            <a
              href={appUrl}
              class="block rounded-lg bg-rose-600 px-4 py-2.5 text-center text-sm font-semibold text-white transition-colors hover:bg-rose-700"
            >
              Acessar Plataforma
            </a>
          </li>
        </ul>
      </div>
    </details>
  </nav>
</header>
